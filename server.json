{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.chrischall/resy-mcp",
  "description": "Resy reservation management \u2014 search, book, cancel, favorites, and Priority Notify for Claude",
  "repository": {
    "url": "https://github.com/chrischall/resy-mcp",
    "source": "github"
  },
  "version": "0.1.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "resy-mcp",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "RESY_EMAIL",
          "description": "Your Resy account email",
          "isRequired": true,
          "format": "string"
        },
        {
          "name": "RESY_PASSWORD",
          "description": "Your Resy account password",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "RESY_API_KEY",
          "description": "Override the public web-app API key (rarely needed)",
          "isRequired": false,
          "format": "string"
        }
      ]
    }
  ]
}
